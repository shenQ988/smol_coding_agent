"""/branch <name> — create a new branch from the current thread and switch to it."""

from langchain_core.messages import HumanMessage
from memory.reduction import summarize_messages


def run(args: str = "", branch_manager=None, graph_config=None, graph=None, llm=None, **kwargs) -> str:
    name = args.strip()
    if not name:
        return "Usage: /branch <name>"
    if branch_manager is None:
        return "Branch manager not available."

    current_thread_id = graph_config["configurable"]["thread_id"]
    try:
        new_tid = branch_manager.create_branch(name, from_thread_id=current_thread_id)
    except ValueError as e:
        return str(e)

    # Seed the new branch checkpoint with required init fields so
    # should_continue never sees a checkpoint missing max_iterations.
    if graph is not None:
        parent_name = branch_manager.get_active()
        parent_state = graph.get_state(graph_config)
        parent_values = parent_state.values if parent_state else {}
        parent_messages = parent_values.get("messages", [])
        # Inherit cap from parent; fall back to 15 if parent was never initialised.
        max_iterations = parent_values.get("max_iterations", 15)

        if llm is not None and parent_messages:
            summary_text = summarize_messages(parent_messages, llm)
            seed_content = f"[Branched from '{parent_name}']\n{summary_text}"
        else:
            seed_content = f"[Branched from '{parent_name}' — no prior context]"

        new_config = {"configurable": {"thread_id": new_tid}}
        graph.update_state(new_config, {
            "messages": [HumanMessage(content=seed_content)],
            "max_iterations": max_iterations,
            "iteration": 0,
            "memory": {"task": "", "files": [], "notes": []},
            "workspace_context": "",
            "last_tool_call": None,
        })

    branch_manager.set_active(name)
    return f"__SWITCH_BRANCH__{new_tid}:{name}\nCreated and switched to branch '{name}'."
